{
  "name": "@platform/auth",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "test:verbose": "node --experimental-test-module-mocks --test --test-reporter=spec tests/*.test.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:migrate": "prisma db push && node prisma/seed.js"
  },
  "dependencies": {
    "@platform/shared": "workspace:*",
    "@prisma/client": "6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "prisma": "6.19.3"
  }
}
