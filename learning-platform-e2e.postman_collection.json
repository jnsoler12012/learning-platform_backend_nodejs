              "path": ["content", "nodes", "INVALID"]
            }
          }
        },
        {
          "name": "US-21: User validates content block structure",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.test(\"Has blocks array\", function () {",
                  "  pm.expect(body).to.have.property(\"blocks\");",
                  "});",
                  "pm.test(\"Blocks is non-empty\", function () {",
                  "  pm.expect(body.blocks.length).to.be.greaterThan(0);",
                  "});",
                  "pm.test(\"First block has type\", function () {",
                  "  pm.expect(body.blocks[0]).to.have.property(\"type\");",
                  "});",
                  "pm.test(\"First block has order\", function () {",
                  "  pm.expect(body.blocks[0]).to.have.property(\"order\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
