{
  "info": {
    "name": "Learning Platform — End-to-End Validation",
    "description": "Single collection that validates all student-accessible endpoints across the Auth (8080), Knowledge (8081), and Content (8082) services. Registers a new user and walks through a complete learning journey: auth, profile, navigation, enrollment, content reading, assessments, notes, and search. Cleans up all created resources at the end.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{user_token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "auth_url", "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "knowledge_url", "value": "http://localhost:8081/api/v1", "type": "string" },
    { "key": "content_url", "value": "http://localhost:8082/api/v1", "type": "string" },
    { "key": "user_token", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "user_email", "value": "testuser@test.com", "type": "string" },
    { "key": "user_password", "value": "Test@123", "type": "string" },
    { "key": "learning_path_id", "value": "", "type": "string" },
    { "key": "assessment_id", "value": "6a20ada0408e222820b34d5e", "type": "string" },
    { "key": "nodeId", "value": "CN10", "type": "string" },
    { "key": "track_name", "value": "Mathematics", "type": "string" },
    { "key": "subtrack_name", "value": "Core Algebraic Spine", "type": "string" }
  ],
  "item": [
    {
      "name": "RF1 — Registration and Authentication",
      "item": [
        {
          "name": "US-01: User registers a new account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201 — User created\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.test(\"Response has token\", function () {",
                  "  pm.expect(body).to.have.property(\"token\");",
                  "});",
                  "pm.test(\"Response has user.id\", function () {",
                  "  pm.expect(body.user).to.have.property(\"id\");",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"user_token\", body.token);",
                  "pm.collectionVariables.set(\"userId\", body.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/register",
              "host": ["{{auth_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "US-02: User logs in with correct credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200 — Login successful\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.test(\"Response has token\", function () {",
                  "  pm.expect(body).to.have.property(\"token\");",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"user_token\", body.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/login",
              "host": ["{{auth_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "US-03: Duplicate registration is rejected",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 409 — Duplicate rejected\", function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.test(\"Error code is CONFLICT\", function () {",
                  "  pm.expect(body.error.code).to.eql(\"CONFLICT\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/register",
              "host": ["{{auth_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "US-04: User updates account password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200 — Account updated\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.test(\"Success message returned\", function () {",
                  "  pm.expect(body).to.have.property(\"message\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Test@123\",\n  \"newPassword\": \"NewPass@456\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/users/me/account",
              "host": ["{{auth_url}}"],
              "path": ["users", "me", "account"]
            }
          }
        },
        {
          "name": "US-05: Login with wrong password returns 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 401 — Unauthorized\", function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.test(\"Error code is UNAUTHORIZED\", function () {",
                  "  pm.expect(body.error.code).to.eql(\"UNAUTHORIZED\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/login",
              "host": ["{{auth_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
