{
  "info": {
    "name": "Student API Tests — Learning Platform",
    "description": "Postman collection for testing the Student Gateway API endpoints. Covers 25 user stories mapped to 8 functional requirements.\n\n## Setup\n1. Start all services (auth on :8080, knowledge on :8081, content on :8082, gateway on :8084)\n2. Run the auth seed, knowledge seed, and content seed to populate test data\n3. Run this collection in order (each test builds on previous results)\n\n## Collection Variables\n- `baseUrl`: Gateway base URL (default: http://localhost:8084/api/student)\n- `token`: JWT token (set automatically by login tests)\n- `testEmail`: Random email generated by US-01\n- `testPassword`: Initial test password\n- `newTestPassword`: Updated password (set by US-04)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8084/api/student"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "testEmail",
      "value": "testing@test.com"
    },
    {
      "key": "testPassword",
      "value": "MyPassword123"
    },
    {
      "key": "newTestPassword",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "RF1 - Registration and Authentication",
      "description": "User registration, login, duplicate rejection, password update, and invalid credential handling.",
      "item": [
        {
          "name": "US-01: User registers a new account",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const randomId = Date.now() + Math.floor(Math.random() * 1000);",
                  "pm.collectionVariables.set('testEmail', `test_student_${randomId}@test.com`);",
                  "pm.collectionVariables.set('testPassword', 'MyPassword123');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response has token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('token');",
                  "  pm.expect(body.token).to.not.be.empty;",
                  "});",
                  "pm.test('Response has user object', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('user');",
                  "  pm.expect(body.user).to.have.property('id');",
                  "  pm.expect(body.user).to.have.property('email');",
                  "  pm.expect(body.user.isActive).to.be.true;",
                  "});",
                  "pm.test('User role is student', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.roles).to.include('student');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Student\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "US-02: User starts session with correct credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('token');",
                  "  pm.expect(body.token).to.not.be.empty;",
                  "});",
                  "pm.test('User is active', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user.isActive).to.be.true;",
                  "});",
                  "pm.test('Roles include student', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.roles).to.include('student');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('token', body.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "US-03: Duplicate registration is rejected",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Error code is CONFLICT', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error.code).to.eql('CONFLICT');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Student\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "US-04: User updates his password",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('newTestPassword', 'NewSecurePass789');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Account updated successfully', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Account updated successfully');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{testPassword}}\",\n  \"newPassword\": \"{{newTestPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/me/account",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me", "account"]
            }
          }
        },
        {
          "name": "US-05: Login with old password is rejected",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 Unauthorized', () => pm.response.to.have.status(401));",
                  "pm.test('Error code is UNAUTHORIZED', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error.code).to.eql('UNAUTHORIZED');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login with new password (helper)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('New password works', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('token');",
                  "  pm.expect(body.token).to.not.be.empty;",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('token', body.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{newTestPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "RF2 - Profile and Learning Objectives",
      "description": "Profile viewing, profile updates, and listing available learning paths.",
      "item": [
        {
          "name": "US-06: User views their own profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains nested user object', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user).to.have.property('user');",
                  "  pm.expect(body.user.user).to.have.property('id');",
                  "  pm.expect(body.user.user).to.have.property('email');",
                  "  pm.expect(body.user.user.isActive).to.be.true;",
                  "});",
                  "pm.test('Response contains profile inside user', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user).to.have.property('profile');",
                  "  pm.expect(body.user.profile).to.have.property('firstName');",
                  "  pm.expect(body.user.profile).to.have.property('lastName');",
                  "});",
                  "pm.test('Response contains roles array inside user', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user).to.have.property('roles');",
                  "  pm.expect(body.user.roles).to.be.an('array');",
                  "});",
                  "pm.test('Response contains learning paths at top level', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('enrolledPaths');",
                  "  pm.expect(body).to.have.property('availablePaths');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "US-07: User updates his display name in profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Display name is updated', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.displayName).to.eql('TestStudent_Updated');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"TestStudent_Updated\",\n  \"preferredLanguage\": \"en\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "US-08: User checks available learning paths",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Available paths is an array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('availablePaths');",
                  "  pm.expect(body.availablePaths).to.be.an('array');",
                  "});",
                  "pm.test('Each available path has required fields', () => {",
                  "  const paths = pm.response.json().availablePaths;",
                  "  paths.forEach(p => {",
                  "    pm.expect(p).to.have.property('id');",
                  "    pm.expect(p).to.have.property('code');",
                  "    pm.expect(p).to.have.property('title');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "RF3 - Topic Navigation and Knowledge Node Visualization",
      "description": "Listing and filtering concepts, querying concept details, and visualizing the knowledge graph.",
      "item": [
        {
          "name": "US-09: User lists concepts filtered by track",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response is an array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "});",
                  "pm.test('All concepts belong to the specified track', () => {",
                  "  const concepts = pm.response.json();",
                  "  concepts.forEach(c => {",
                  "    pm.expect(c.track).to.eql('Mathematics');",
                  "  });",
                  "});",
                  "pm.test('Each concept has required fields', () => {",
                  "  const concepts = pm.response.json();",
                  "  concepts.forEach(c => {",
                  "    pm.expect(c).to.have.property('id');",
                  "    pm.expect(c).to.have.property('name');",
                  "    pm.expect(c).to.have.property('difficulty');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/concepts?track=Mathematics",
              "host": ["{{baseUrl}}"],
              "path": ["concepts"],
              "query": [
                {
                  "key": "track",
                  "value": "Mathematics"
                }
              ]
            }
          }
        },
        {
          "name": "US-10: User queries detail of a concept with its relationships",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Returns the correct concept', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql('CN05');",
                  "  pm.expect(body).to.have.property('name');",
                  "});",
                  "pm.test('Has prerequisites array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('prerequisites');",
                  "  pm.expect(body.prerequisites).to.be.an('array');",
                  "});",
                  "pm.test('Has dependents array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('dependents');",
                  "  pm.expect(body.dependents).to.be.an('array');",
                  "});",
                  "pm.test('Has related array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('related');",
                  "  pm.expect(body.related).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/concepts/CN05",
              "host": ["{{baseUrl}}"],
              "path": ["concepts", "CN05"]
            }
          }
        },
        {
          "name": "US-11: User visualizes the complete knowledge graph",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has nodes array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('nodes');",
                  "  pm.expect(body.nodes).to.be.an('array');",
                  "});",
                  "pm.test('Response has edges array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('edges');",
                  "  pm.expect(body.edges).to.be.an('array');",
                  "});",
                  "pm.test('Response has userTracks and learningPaths', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('userTracks');",
                  "  pm.expect(body).to.have.property('learningPaths');",
                  "});",
                  "pm.test('Each node has id, name, track', () => {",
                  "  const body = pm.response.json();",
                  "  body.nodes.forEach(n => {",
                  "    pm.expect(n).to.have.property('id');",
                  "    pm.expect(n).to.have.property('name');",
                  "    pm.expect(n).to.have.property('track');",
                  "  });",
                  "});",
                  "pm.test('Each edge has from, to, type', () => {",
                  "  const body = pm.response.json();",
                  "  body.edges.forEach(e => {",
                  "    pm.expect(e).to.have.property('from');",
                  "    pm.expect(e).to.have.property('to');",
                  "    pm.expect(e).to.have.property('type');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/graph",
              "host": ["{{baseUrl}}"],
              "path": ["graph"]
            }
          }
        },
        {
          "name": "US-12: User visualizes the knowledge graph filtered by track",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has nodes and edges', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('nodes');",
                  "  pm.expect(body).to.have.property('edges');",
                  "  pm.expect(body.nodes).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/graph/track/Mathematics",
              "host": ["{{baseUrl}}"],
              "path": ["graph", "track", "Mathematics"]
            }
          }
        }
      ]
    },
    {
      "name": "RF4 - Learning Pathways and Progression Control",
      "description": "Enrolling in a learning path and consulting enrolled paths.",
      "item": [
        {
          "name": "US-13: User signs up for a learning path",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has enrolledPaths array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('enrolledPaths');",
                  "  pm.expect(body.enrolledPaths).to.be.an('array');",
                  "});",
                  "pm.test('Enrolled path includes Math', () => {",
                  "  const paths = pm.response.json().enrolledPaths;",
                  "  const mathPath = paths.find(p => p.code === 'Math' || p.title.includes('Math'));",
                  "  pm.expect(mathPath).to.exist;",
                  "  pm.expect(mathPath.isActive).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codes\": [\"Math\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/learning-paths",
              "host": ["{{baseUrl}}"],
              "path": ["learning-paths"]
            }
          }
        },
        {
          "name": "US-14: User consults their registered learning paths",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Enrolled paths is a non-empty array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('enrolledPaths');",
                  "  pm.expect(body.enrolledPaths).to.be.an('array');",
                  "  pm.expect(body.enrolledPaths.length).to.be.greaterThan(0);",
                  "});",
                  "pm.test('Enrolled path has progress and isActive fields', () => {",
                  "  const paths = pm.response.json().enrolledPaths;",
                  "  paths.forEach(p => {",
                  "    pm.expect(p).to.have.property('code');",
                  "    pm.expect(p).to.have.property('progress');",
                  "    pm.expect(p).to.have.property('isActive');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "RF5 - Knowledge Base Access and Interaction",
      "description": "Reading existing content, handling non-existent nodes, and validating content block structure.",
      "item": [
        {
          "name": "US-17: User reads the content of an existing knowledge node",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has concept and content', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('concept');",
                  "  pm.expect(body).to.have.property('content');",
                  "});",
                  "pm.test('Concept has required metadata', () => {",
                  "  const concept = pm.response.json().concept;",
                  "  pm.expect(concept).to.have.property('id');",
