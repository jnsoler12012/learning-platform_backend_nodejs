{
  "name": "learning-platform-v3",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma"
    ]
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @platform/auth --filter @platform/knowledge --filter @platform/content --filter @platform/gateway dev",
    "dev:exposed": "pnpm --parallel --filter @platform/auth --filter @platform/knowledge --filter @platform/content --filter @platform/gateway dev",
    "dev:local": "HOST=127.0.0.1 pnpm --parallel --filter @platform/auth --filter @platform/knowledge --filter @platform/content --filter @platform/gateway dev",
    "dev:knowledge": "pnpm --filter @platform/knowledge dev",
    "dev:content": "pnpm --filter @platform/content dev",
    "start": "pnpm --filter @platform/auth start",
    "test": "pnpm --filter @platform/auth test",
    "db:generate": "pnpm --filter @platform/auth db:generate",
    "db:push": "pnpm --filter @platform/auth db:push",
    "db:seed": "pnpm --filter @platform/auth db:seed",
    "db:migrate": "pnpm --filter @platform/auth db:migrate"
  }
}